{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rm:*)",
      "Bash(git stash)",
      "Bash(git stash:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(grep:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(sudo)",
      "Bash(sudo:*)",
      "Bash(rm)",
      "Bash(rm:*)",
      "Bash(curl)",
      "Bash(curl:*)",
      "Bash(wget)",
      "Bash(wget:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"確認を待っています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスクが完了しました\" with title \"Claude Code\" subtitle \"応答完了\" sound name \"Hero\"'"
          }
        ]
      }
    ]
  }
}
